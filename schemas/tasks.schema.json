{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.ai/schemas/tasks.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "workspace_id",
    "title",
    "status",
    "priority",
    "type",
    "dependency_ids",
    "tags",
    "auto_execute",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "workspace_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "format": "uuid" },
    "parent_task_id": { "type": "string", "format": "uuid" },
    "objective_id": { "type": "string", "format": "uuid" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "blocked", "completed"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "critical"]
    },
    "type": {
      "type": "string",
      "enum": ["action", "approval", "research", "maintenance"]
    },
    "assigned_agent_id": { "type": "string", "format": "uuid" },
    "requested_by_agent_id": { "type": "string", "format": "uuid" },
    "due_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "blocked_reason": { "type": "string" },
    "dependency_ids": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "auto_execute": { "type": "boolean" },
    "history_cursor": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
