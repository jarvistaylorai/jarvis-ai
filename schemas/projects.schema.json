{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.ai/schemas/projects.schema.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "workspace_id",
    "name",
    "status",
    "priority",
    "health_score",
    "progress_percent",
    "objective_ids",
    "tags",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "workspace_id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "building", "testing", "launched", "paused"]
    },
    "priority": {
      "type": "string",
      "enum": ["mission_critical", "high", "medium", "low"]
    },
    "owner_agent_id": { "type": "string", "format": "uuid" },
    "health_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "progress_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "start_date": { "type": "string", "format": "date-time" },
    "due_date": { "type": "string", "format": "date-time" },
    "active_sprint": { "type": "string" },
    "objective_ids": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "metadata": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
